{
  "name": "react-stateshape",
  "version": "0.2.2",
  "description": "A shared state management and routing lib for React apps",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "demo": "npx auxsrv tests/Shared_state_without_Context",
    "preversion": "npx npm-run-all shape test",
    "shape": "npx codeshape",
    "t3": "npx auxsrv tests/Tic-tac-toe",
    "test": "npx playwright test --project=chromium",
    "typecheck": "npx codeshape typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axtk/react-stateshape.git"
  },
  "keywords": [
    "state",
    "state management",
    "react state management",
    "shared state",
    "global state",
    "routing",
    "react router"
  ],
  "license": "MIT",
  "author": "axtk",
  "peerDependencies": {
    "react": ">=16.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "auxsrv": "^0.3.2",
    "immer": "^11.1.4",
    "react-dom": "^19.2.4",
    "url-shape": "^1.3.15",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "stateshape": "^0.2.1"
  }
}
